# Path to your malware scanner project (absolute or relative to this file)
MALWARE_PROJECT_PATH=./../Full Malware Detection ML/Full Malware Detection ML

# Threat Intelligence API Keys (used by malware scanner)
OTX_API_KEY=your_otx_key_here
MALWAREBAZAAR_API_KEY=
URLHAUS_API_KEY=

# Dynamic Analysis (future)
ENABLE_DYNAMIC=false
ANYRUN_API_KEY=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
